# ============================================================
# PatternOS — Environment Variable Template
# Copy this to .env and fill in your values.
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=patternos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary: x-ai/grok-4.1-fast — Fallback: deepseek/deepseek-v3.2
LLM_REASONING_MODEL=x-ai/grok-4.1-fast
LLM_CHAT_MODEL=x-ai/grok-4.1-fast
LLM_SCREENING_MODEL=x-ai/grok-4.1-fast
LLM_FALLBACK_MODEL=deepseek/deepseek-v3.2
LLM_DISABLED=false

# PatternOS Telegram bot token (BotFather) + numeric chat id for alert destination
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MODE=disabled
TELEGRAM_ALERTS_ENABLED=true
# Optional allowlists (comma-separated). If empty, defaults to TELEGRAM_CHAT_ID only.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USERNAMES=
TELEGRAM_ALERT_MAX_ATTEMPTS=10

# Indicators engine: auto prefers TA-Lib if installed
INDICATOR_ENGINE=auto

APP_ENV=development
# Background scheduler (daily equity scan, MF ingest, cache cleanup, Telegram). Set false on a small VPS if you only need the REST API.
SCHEDULER_ENABLED=true
BACKEND_PORT=8000
FRONTEND_PORT=3000
SIGNAL_CONFIDENCE_THRESHOLD=70
# Pre-inbox equity desk (LLM + optional web). If SearxNG returns nothing, DuckDuckGo instant answers are used.
SIGNAL_DEEP_REVIEW_ENABLED=true
SEARXNG_BASE_URL=
CRAWL4AI_BASE_URL=
CORS_ORIGINS=http://localhost:3000

# --- Mutual funds ingestion (Equity + Direct Growth outbound scope by default) ---
MF_INGESTION_ENABLED=true
MF_BACKFILL_ENABLED=false
MF_HOLDINGS_ENABLED=true
MF_HOLDINGS_BOOTSTRAP_MAX_MONTHS=240
MF_GAPFILL_MAX_SCHEMES=4000
# Per-call cap when promoting schemes-with-NAV to monitored (0 = unlimited).
MF_MARK_MONITORED_NAV_LIMIT=2500
# Pacing (seconds) between per-scheme outbound calls — raise if you see HTTP 429 / blocks.
MF_GAPFILL_INTER_SCHEME_SLEEP_S=0.35
MF_BACKFILL_INTER_SCHEME_SLEEP_S=0.25
MF_ENRICH_INTER_SCHEME_SLEEP_S=0.3
MF_BACKFILL_MAX_WINDOWS_PER_SCHEME_PER_RUN=3
# Requests/minute caps (single-process limiter; see app/mf/safety.py).
MF_MAX_RPM_MFDATA_STANDARD=36
MF_MAX_RPM_MFDATA_NAV=48
MF_MAX_RPM_MFDATA_ANALYTICS=12
MF_MAX_RPM_MFAPI=12

# Optional: extracted folder from Kaggle (tharunreddy2911/mutual-fund-data) for backend/scripts/mf_seed_historical.py
# (avoids passing --kaggle-dir). Example after unzip under repo root: ../../data/mf-kaggle
# MF_KAGGLE_DATA_DIR=/absolute/path/to/mf-kaggle-extracted

# Kaggle Indian MF historic bundle (same files; dataset page):
# https://www.kaggle.com/datasets/tharunreddy2911/mutual-fund-data
# Local Kaggle flow: kaggle datasets download … && unzip … then run from backend/:
#   ../.venv/bin/python scripts/mf_seed_historical.py --kaggle-dir ../../data/mf-kaggle
# After a full seed, align watchlist + latest NAV (replace host if needed):
#   curl -X POST http://127.0.0.1:8000/api/v1/mf/pipeline/watchlist/sync-priority-amc
#   curl -X POST http://127.0.0.1:8000/api/v1/mf/pipeline/nav/run
#
# Prod: point POSTGRES_* at live DB (or tunnel), run mf_seed_historical.py, then those POSTs.
# SQL (replace 147541): duplicates → expect 0 rows —
#   SELECT scheme_code,nav_date,COUNT(*)c FROM mf_nav_daily WHERE scheme_code=147541 GROUP BY 1,2 HAVING COUNT(*)>1;
# Coverage —
#   SELECT COUNT(*),MIN(nav_date),MAX(nav_date) FROM mf_nav_daily WHERE scheme_code=147541;
MF_HISTORICAL_PARQUET_URL=https://github.com/InertExpert2911/Mutual_Fund_Data/raw/main/mutual_fund_nav_history.parquet
MF_HISTORICAL_SCHEMES_CSV_URL=https://github.com/InertExpert2911/Mutual_Fund_Data/raw/main/mutual_fund_data.csv
